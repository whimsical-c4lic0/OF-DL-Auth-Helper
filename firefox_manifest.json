{
    "manifest_version": 3,
    "name": "OF-DL Auth Helper",
    "version": "0.0.9",
    "description": "Helper extension that makes it easier to copy auth.json values for the OF-DL",
    "icons": {
        "48": "icons/cookie.png"
    },
    "background": {
        "scripts": [
            "background/background.js"
        ]
    },
    "permissions": [
        "cookies",
        "clipboardWrite",
        "storage",
        "contextualIdentities"
    ],
    "optional_permissions": [
        "userScripts"
    ],
    "host_permissions": [
        "*://onlyfans.com/*",
        "*://*.onlyfans.com/*"
    ],
    "action": {
        "default_icon": {
            "48": "icons/cookie.png"
        },
        "default_title": "OF-DL Auth Helper",
        "default_popup": "popup/cookies.html"
    },
    "content_scripts": [
        {
            "matches": [
                "*://onlyfans.com/",
                "*://onlyfans.com/*",
                "*://*.onlyfans.com/",
                "*://*.onlyfans.com/*"
            ],
            "js": [
                "content_scripts/bcToken.js"
            ]
        }
    ]
}
